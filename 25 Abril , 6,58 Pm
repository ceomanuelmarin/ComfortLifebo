        <div id="toast" class="fixed bottom-6 lg:bottom-10 left-1/2 -translate-x-1/2 px-6 py-3 bg-slate-900 text-white rounded-full text-[9px] lg:text-[10px] font-black uppercase translate-y-28 transition-transform z-[500] italic text-center whitespace-nowrap shadow-2xl border border-slate-700"></div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-comfort text-white pt-5 pb-3 px-4 lg:px-8 italic text-center mt-3 lg:mt-6 shrink-0 border-t-4 border-blue-800">
