<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Comfort Life | Salud Integral Bolivia</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
        
        :root {
            --comfort-blue: #1e3a8a;
            --comfort-light: #f8fafc;
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--comfort-light);
            scroll-behavior: smooth;
            -webkit-user-select: none;
            user-select: none;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        input, textarea, select {
            -webkit-user-select: text;
            user-select: text;
        }

        img {
            -webkit-user-drag: none;
            -khtml-user-drag: none;
            -moz-user-drag: none;
            -o-user-drag: none;
            user-drag: none;
            -webkit-touch-callout: none;
        }

        .text-comfort { color: var(--comfort-blue); }
        .bg-comfort { background-color: var(--comfort-blue); }

        #mobile-drawer { transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .drawer-open { transform: translateX(0) !important; }
        
        #cart-drawer { transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .cart-open { transform: translateX(0) !important; }

        .product-card { transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .product-card:hover { transform: translateY(-12px); box-shadow: 0 40px 60px -15px rgba(30, 58, 138, 0.15); }

        .admin-tab-active { color: var(--comfort-blue); border-bottom: 3px solid var(--comfort-blue); font-weight: 800; }
        .no-scrollbar::-webkit-scrollbar { display: none; }

        details summary::-webkit-details-marker { display: none; }

        .img-carousel {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
        }
        .img-carousel::-webkit-scrollbar { display: none; }
        .img-carousel img {
            flex: 0 0 100%;
            scroll-snap-align: center;
            object-fit: cover;
        }

        .safe-iframe-wrapper {
            width: 100%;
            height: 800px;
            overflow: hidden;
            border-radius: 2rem;
            background: white;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
        }

        #safe-frame-container { 
            width: 100%; 
            height: 100%; 
            border: none; 
        }

        .pulse-img { animation: soft-pulse 4s infinite ease-in-out; }
        @keyframes soft-pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.03); } }

        #product-modal-container { transition: all 0.3s ease-out; }
        .modal-show { opacity: 1 !important; pointer-events: auto !important; transform: scale(1) !important; }
        
        /* Radios personalizados para métodos de pago */
        .pay-radio:checked + div { border-color: var(--comfort-blue); background-color: #eff6ff; }
        .pay-radio:checked + div .pay-icon { color: var(--comfort-blue); transform: scale(1.1); }
        
        main { flex-grow: 1; }
    </style>
</head>
<body class="text-slate-900" oncontextmenu="return false;">

    <nav class="sticky top-0 z-[100] bg-white/90 backdrop-blur-xl border-b border-slate-100 shadow-sm px-4 lg:px-8">
        <div class="max-w-7xl mx-auto h-16 lg:h-20 flex justify-between items-center">
            <div class="flex items-center gap-3 cursor-pointer" onclick="showSection('home')">
                <div class="w-10 h-10 lg:w-12 lg:h-12 bg-comfort rounded-xl lg:rounded-2xl flex items-center justify-center text-white font-black text-xl lg:text-2xl shadow-lg">CL</div>
                <div class="leading-none text-left">
                    <span class="block font-black text-lg lg:text-xl text-comfort uppercase tracking-tighter italic">ComfortLife</span>
                    <span class="text-[8px] lg:text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em] mt-1 italic">BOLIVIA</span>
                </div>
            </div>
            <div class="hidden lg:flex items-center gap-8 font-black text-[10px] uppercase tracking-widest text-slate-500" id="pc-nav"></div>
            <div class="flex items-center gap-2 lg:gap-4">
                <button onclick="window.toggleCart()" class="relative p-2 text-slate-600 hover:text-comfort transition flex items-center justify-center bg-slate-50 rounded-xl lg:rounded-2xl w-10 h-10 lg:w-12 lg:h-12">
                    <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                    <span id="cart-count-badge" class="absolute -top-1 -right-1 bg-red-500 text-white text-[9px] lg:text-[10px] font-black w-5 h-5 rounded-full flex items-center justify-center shadow-sm border-2 border-white transition-transform scale-0">0</span>
                </button>
                <button onclick="openAuthModal()" class="hidden md:block px-6 py-2.5 rounded-full border-2 border-slate-100 text-[10px] font-black uppercase hover:border-comfort transition">Admin</button>
                <button onclick="toggleDrawer()" class="lg:hidden p-2 bg-slate-100 rounded-xl text-comfort w-10 h-10 flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16m-7 6h7"/></svg>
                </button>
            </div>
        </div>
    </nav>

    <!-- DRAWER NAVEGACIÓN -->
    <div id="drawer-overlay" onclick="toggleDrawer()" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[150] opacity-0 pointer-events-none hidden transition-opacity duration-300"></div>
    <div id="mobile-drawer" class="fixed top-0 right-0 h-full w-[320px] bg-white z-[200] shadow-2xl translate-x-full overflow-y-auto">
        <div class="p-6 lg:p-8 border-b border-slate-50 flex justify-between items-center sticky top-0 bg-white">
            <span class="font-black text-comfort italic uppercase text-lg text-left">ComfortLife</span>
            <button onclick="toggleDrawer()" class="text-slate-300 hover:text-comfort p-2">✕</button>
        </div>
        <div class="p-6 lg:p-8 space-y-10" id="mobile-nav-dynamic"></div>
    </div>

    <!-- DRAWER CARRITO -->
    <div id="cart-overlay" onclick="window.toggleCart()" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[150] opacity-0 pointer-events-none hidden transition-opacity duration-300"></div>
    <div id="cart-drawer" class="fixed top-0 right-0 h-full w-full sm:w-[400px] bg-white z-[200] shadow-2xl translate-x-full flex flex-col">
        <div class="p-5 lg:p-6 border-b border-slate-50 flex justify-between items-center bg-white shrink-0">
            <div class="flex items-center gap-2 text-comfort">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                <span class="font-black italic uppercase tracking-tighter text-xl">Tu Carrito</span>
            </div>
            <button onclick="window.toggleCart()" class="text-slate-400 hover:text-comfort p-2 bg-slate-50 rounded-full w-8 h-8 flex items-center justify-center">✕</button>
        </div>
        
        <div id="cart-items-container" class="flex-grow overflow-y-auto p-5 space-y-4 no-scrollbar bg-slate-50/50">
            <!-- Items del carrito -->
        </div>

        <div class="p-5 lg:p-6 border-t border-slate-100 bg-white shrink-0 shadow-[0_-10px_20px_rgba(0,0,0,0.02)]">
            <div class="flex justify-between items-center mb-4">
                <span class="text-xs font-black uppercase tracking-widest text-slate-400">Total a Pagar</span>
                <span class="text-2xl font-black text-comfort italic"><span id="cart-total-price">0</span> Bs.</span>
            </div>
            <button onclick="window.goToCheckout()" id="btn-go-checkout" class="w-full py-4 bg-comfort text-white rounded-2xl font-black uppercase text-xs tracking-widest shadow-xl hover:scale-[1.02] transition-transform disabled:opacity-50 disabled:pointer-events-none">Procesar Pedido</button>
        </div>
    </div>

    <main>
        <section id="section-home" class="animate-in fade-in duration-500">
            <div class="max-w-7xl mx-auto px-4 lg:px-6 py-4 lg:py-10 grid lg:grid-cols-2 gap-4 lg:gap-10 items-center text-left">
                <div class="space-y-4 lg:space-y-6 italic">
                    <h1 class="text-4xl md:text-6xl font-black uppercase tracking-wide leading-tight text-slate-900">Salud en <span class="text-blue-600">Cada Paso</span></h1>
                    <p class="text-sm lg:text-lg font-medium text-slate-500 leading-relaxed max-w-lg italic">Expertos en Bolivia en soluciones ortopédicas avanzadas diseñadas para el alivio plantar y corrección postural.</p>
                    <div class="flex flex-wrap gap-2 lg:gap-4 pt-2">
                        <button onclick="showSection('catalog')" class="px-6 py-3 lg:px-8 lg:py-4 bg-comfort text-white rounded-full font-black uppercase text-[9px] lg:text-[10px] tracking-widest shadow-xl hover:scale-105 transition-all">Explorar Catálogo</button>
                        <button onclick="document.getElementById('home-ai-section').scrollIntoView({behavior: 'smooth'})" class="px-6 py-3 lg:px-8 lg:py-4 border-2 border-blue-100 text-blue-600 rounded-full font-black uppercase text-[9px] lg:text-[10px] tracking-widest hover:bg-blue-50 transition-all flex items-center gap-2 italic">Asistente ComfortLife IA ✨</button>
                    </div>
                </div>
                <div class="relative flex justify-center lg:justify-end mt-4 lg:mt-0">
                    <div class="relative group">
                        <div class="absolute inset-0 bg-blue-100 rounded-[3rem] blur-2xl opacity-40 group-hover:opacity-60 transition-all"></div>
                        <img src="https://images.unsplash.com/photo-1519415510236-85592ac7530b?auto=format&fit=crop&q=80&w=600" class="relative w-full max-w-[280px] lg:max-w-md rounded-[2.5rem] shadow-2xl border-4 lg:border-8 border-white pulse-img object-cover">
                    </div>
                </div>
            </div>

            <div id="home-ai-section" class="max-w-4xl mx-auto px-4 lg:px-6 py-2">
                <div class="bg-white rounded-[2rem] lg:rounded-full shadow-lg border border-slate-100 overflow-hidden flex flex-col lg:flex-row items-center p-2 lg:p-2.5 gap-2 italic">
                    <div class="bg-comfort text-white px-4 py-2 lg:py-3 rounded-full flex items-center justify-center gap-2 shrink-0 w-full lg:w-auto shadow-inner">
                        <span class="text-sm">✨</span>
                        <span class="font-black uppercase tracking-widest text-[9px]">Asistente IA</span>
                    </div>
                    <div class="flex-grow w-full flex flex-col">
                        <div id="ai-messages-embedded" class="max-h-[120px] overflow-y-auto px-2 py-1 text-[10px] space-y-1.5 no-scrollbar flex flex-col">
                            <div class="text-slate-500 font-bold self-start bg-slate-50 px-3 py-1.5 rounded-xl rounded-tl-none border border-slate-100 shadow-sm">¡Hola! ¿En qué te puedo ayudar hoy de forma rápida?</div>
                        </div>
                    </div>
                    <div class="flex gap-2 w-full lg:w-[320px] shrink-0 mt-1 lg:mt-0">
                        <input type="text" id="ai-input-embedded" class="flex-grow px-4 py-2.5 bg-slate-50 text-[10px] lg:text-xs font-bold outline-none rounded-full border border-slate-100 focus:border-blue-200 transition" placeholder="Escribe tu consulta..." onkeypress="if(event.key === 'Enter') window.askAI('embedded')">
                        <button onclick="window.askAI('embedded')" class="w-10 h-10 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center shrink-0 hover:bg-blue-100 transition shadow-sm font-black">➤</button>
                    </div>
                </div>
            </div>

            <div class="py-6 lg:py-12 bg-white mt-4 rounded-t-[2.5rem] lg:rounded-t-[4rem]">
                <div class="max-w-7xl mx-auto px-4 lg:px-6">
                    <div class="mb-4 lg:mb-8 text-center italic">
                        <h2 class="text-3xl lg:text-4xl font-black text-slate-900 uppercase tracking-wide">Líneas de Cuidado</h2>
                        <div class="w-16 h-1.5 bg-comfort mx-auto mt-3 rounded-full"></div>
                    </div>
                    <div id="category-grid" class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-2 lg:gap-8"></div>
                </div>
            </div>
        </section>

        <section id="section-catalog" class="hidden py-6 lg:py-10 px-4 lg:px-6 max-w-7xl mx-auto">
            <div class="flex flex-col lg:flex-row justify-between items-center gap-4 mb-6 italic text-left">
                <div class="space-y-1 text-center lg:text-left">
                    <h2 class="text-4xl lg:text-6xl font-black text-slate-900 uppercase tracking-tighter leading-none">Catálogo</h2>
                    <p class="text-slate-400 font-bold uppercase tracking-[0.3em] text-[8px] lg:text-[9px]">Encuentra tu solución</p>
                </div>
                <div class="w-full lg:w-96 relative">
                    <input type="text" id="catalog-search" oninput="window.filterCatalogUI()" placeholder="🔍 Buscar producto..." class="w-full p-3.5 lg:p-5 bg-white border border-slate-100 rounded-full text-xs italic outline-none shadow-sm focus:ring-4 focus:ring-blue-50">
                </div>
            </div>
            <div id="filter-bar" class="flex flex-wrap gap-1.5 lg:gap-2 justify-center mb-6 italic"></div>
            <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2 lg:gap-6"></div>
        </section>

        <!-- SECCIÓN CHECKOUT COMPACTO -->
        <section id="section-checkout" class="hidden py-6 lg:py-10 px-4 lg:px-6 max-w-4xl mx-auto animate-in slide-in-from-right duration-500 italic text-left">
            <button onclick="window.toggleCart()" class="flex items-center gap-2 text-slate-400 font-black uppercase text-[9px] hover:text-comfort transition mb-4 group">
                <span class="group-hover:-translate-x-1 transition-transform">←</span> Volver al Carrito
            </button>
            
            <div class="flex flex-col lg:flex-row gap-4 lg:gap-6">
                <!-- Formulario -->
                <div class="w-full lg:w-3/5">
                    <div class="bg-white p-4 lg:p-6 rounded-[1.5rem] lg:rounded-[2rem] border border-slate-100 shadow-sm mb-4">
                        <h2 class="text-xl font-black uppercase text-comfort mb-4 tracking-tighter flex items-center gap-2"><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg> Datos de Envío</h2>
                        <form id="checkout-form" class="space-y-3">
                            <input type="text" id="co-name" required placeholder="Nombre Completo" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl outline-none font-bold text-xs focus:ring-2 focus:ring-blue-100 focus:border-blue-400 transition">
                            <!-- Validación estricta solo números para teléfono -->
                            <input type="tel" id="co-phone" required pattern="[0-9]*" oninput="this.value = this.value.replace(/[^0-9]/g, '')" placeholder="Nro. WhatsApp (Ej: 71234567)" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl outline-none font-bold text-xs focus:ring-2 focus:ring-blue-100 focus:border-blue-400 transition">
                            
                            <select id="co-city" required onchange="window.handleCityChange()" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl outline-none font-bold text-xs text-slate-600 focus:ring-2 focus:ring-blue-100 focus:border-blue-400 transition cursor-pointer appearance-none">
                                <option value="" disabled selected>Selecciona tu Ciudad</option>
                                <option value="Santa Cruz">Santa Cruz</option>
                                <option value="Cochabamba">Cochabamba</option>
                                <option value="La Paz">La Paz</option>
                                <option value="Sucre">Sucre</option>
                                <option value="Tarija">Tarija</option>
                                <option value="Oruro">Oruro</option>
                                <option value="Potosí">Potosí</option>
                                <option value="Beni">Beni</option>
                                <option value="Pando">Pando</option>
                                <option value="El Alto">El Alto</option>
                                <option value="Otro Lugar">Otro Lugar...</option>
                            </select>
                            
                            <input type="text" id="co-city-other" placeholder="Escribe tu ciudad o municipio" class="hidden w-full p-3 bg-blue-50 border border-blue-200 rounded-xl outline-none font-bold text-xs text-blue-800 transition">
                            
                            <input type="text" id="co-address" placeholder="Dirección exacta (Recomendado)" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl outline-none font-bold text-xs focus:ring-2 focus:ring-blue-100 focus:border-blue-400 transition">
                            
                            <h3 class="text-xs font-black uppercase text-slate-400 tracking-widest mt-4 pt-3 border-t border-slate-100">Método de Pago</h3>
                            <div class="grid grid-cols-2 gap-2 mt-2 transition-all duration-300" id="payment-methods-container">
                                <label class="relative cursor-pointer group transition-all" id="pay-label-efectivo">
                                    <input type="radio" name="co-payment" value="Efectivo" id="pay-radio-efectivo" class="peer sr-only pay-radio" checked>
                                    <div class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 transition-all text-center h-full flex flex-col justify-center items-center gap-1">
                                        <span class="pay-icon text-xl transition-transform block">💵</span>
                                        <span class="font-black text-[9px] uppercase text-slate-700 block">Pago en Efectivo</span>
                                        <span class="text-[7px] text-slate-400 font-bold block">Al recibir tu pedido</span>
                                    </div>
                                </label>
                                <label class="relative cursor-pointer group transition-all" id="pay-label-qr">
                                    <input type="radio" name="co-payment" value="QR / Transferencia" id="pay-radio-qr" class="peer sr-only pay-radio">
                                    <div class="p-3 border-2 border-slate-100 rounded-xl hover:bg-slate-50 transition-all text-center h-full flex flex-col justify-center items-center gap-1">
                                        <span class="pay-icon text-xl transition-transform block">📱</span>
                                        <span class="font-black text-[9px] uppercase text-slate-700 block">Pago por QR</span>
                                        <span class="text-[7px] text-slate-400 font-bold block">Transferencia bancaria</span>
                                    </div>
                                </label>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Resumen -->
                <div class="w-full lg:w-2/5">
                    <div class="bg-slate-50 p-4 lg:p-6 rounded-[1.5rem] lg:rounded-[2rem] border border-slate-200 sticky top-24">
                        <h3 class="text-sm font-black uppercase text-slate-800 mb-3 tracking-tighter">Resumen del Pedido</h3>
                        <div id="checkout-summary-items" class="space-y-2 max-h-[150px] overflow-y-auto no-scrollbar mb-3"></div>
                        <div class="border-t border-slate-200 pt-3 flex justify-between items-end mb-4">
                            <span class="text-[10px] font-black uppercase text-slate-500 tracking-widest">Total a Pagar</span>
                            <span class="text-3xl font-black text-comfort italic leading-none"><span id="checkout-total">0</span> <span class="text-sm">Bs.</span></span>
                        </div>
                        <button onclick="window.processCheckout(event)" class="w-full py-4 bg-[#25D366] text-white rounded-2xl font-black uppercase text-[10px] tracking-widest shadow-xl shadow-green-200 hover:scale-[1.02] transition-transform flex items-center justify-center gap-2">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.876 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                            Completar por WhatsApp
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <section id="section-custom" class="hidden py-6 lg:py-10 px-4 lg:px-6 max-w-7xl mx-auto animate-in slide-in-from-right duration-500 italic text-left">
            <div class="flex justify-between items-center mb-4 lg:mb-6">
                <button onclick="showSection('catalog')" class="flex items-center gap-2 text-slate-400 font-black uppercase text-[9px] lg:text-[10px] hover:text-comfort transition group">
                    <span class="group-hover:-translate-x-1 transition-transform">←</span> Volver al catálogo
                </button>
                <button id="custom-share-btn" class="bg-slate-100 text-slate-600 px-3 py-2 rounded-xl text-[9px] font-black uppercase shadow-sm hover:bg-slate-200 transition flex items-center gap-1.5">🔗 Compartir</button>
            </div>
            <div id="custom-renderer" class="prose prose-slate max-w-none text-sm lg:text-base"></div>
        </section>

        <!-- MODAL VISTA RÁPIDA -->
        <div id="product-modal-container" class="fixed inset-0 z-[350] bg-slate-900/80 backdrop-blur-md opacity-0 pointer-events-none hidden flex items-center justify-center p-3 lg:p-6">
            <div class="bg-white w-full max-w-4xl rounded-[2rem] lg:rounded-[3.5rem] shadow-2xl overflow-hidden transform scale-90 transition-all duration-300 relative flex flex-col max-h-screen">
