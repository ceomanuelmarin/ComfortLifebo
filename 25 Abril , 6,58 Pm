    </footer>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getFirestore, collection, doc, setDoc, getDoc, addDoc, onSnapshot, deleteDoc, updateDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";

        const firebaseConfig = JSON.parse(__firebase_config);
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'comfort-life-master-ecom';
        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);
        const apiKey = ""; 

        // ESTADO GLOBAL
        let products = [], categories = [], badges = [], pages = [], templates = [], faqs = [], policies = [], promos = [];
        let orders = [], sellers = [], customers = [];
        let cart = []; // In-memory cart
        
        let aiSystemPrompt = "Eres el experto en ortopedia de Comfort Life Bolivia. TUS RESPUESTAS DEBEN SER MUY BREVES, CONCISAS Y DIRECTAS (Máximo 2 párrafos cortos). Sé amable, claro y ayuda al cliente.";
        let currentUser = null;
        let currentCatFilter = 'Todos';
        let isDeepLinkProcessed = false;
        
        // Estado Selección Variante Modal/Landing
        window.currentSelectedVariant = null;

        // --- SISTEMA CARRUSEL DE IMAGENES ---
        window.scrollCarousel = (id, dir) => {
            const el = document.getElementById(id);
            if(el) {
                el.scrollBy({ left: dir * (el.clientWidth * 0.9), behavior: 'smooth' });
            }
        };

        function getImgArray(val) {
            if(!val) return [];
            try { const parsed = JSON.parse(val); return Array.isArray(parsed) ? parsed : [val]; } catch(e) { return [val]; }
        }

        async function compressImage(base64Str, maxWidth = 600, quality = 0.5) {
            return new Promise((resolve) => {
                const img = new Image(); img.src = base64Str;
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    let width = img.width; let height = img.height;
                    if (width > maxWidth) { height = (maxWidth / width) * height; width = maxWidth; }
                    canvas.width = width; canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    resolve(canvas.toDataURL('image/jpeg', quality));
                };
            });
        }

        async function copyToClipboard(text) {
            try { await navigator.clipboard.writeText(text); return true; } 
            catch (err) {
                const ta = document.createElement("textarea"); ta.value = text;
                document.body.appendChild(ta); ta.focus(); ta.select();
                try { document.execCommand('copy'); document.body.removeChild(ta); return true; } catch (e) { document.body.removeChild(ta); return false; }
            }
        }

        window.shareLink = async (type, identifier, event) => {
            if (event) { event.stopPropagation(); event.preventDefault(); }
            let finalUrl = `${window.location.origin}${window.location.pathname}?${type}=${encodeURIComponent(identifier)}`;
            const sData = { title: 'Comfort Life Bolivia', text: 'Mira esto en Comfort Life:', url: finalUrl };
            try { if (navigator.share) await navigator.share(sData); else { await copyToClipboard(finalUrl); window.showToast("Enlace copiado 🔗"); } } 
            catch (err) { await copyToClipboard(finalUrl); window.showToast("Copiado al portapapeles 📋"); }
        };

        window.processDeepLink = () => {
            if(isDeepLinkProcessed || products.length === 0) return;
            const params = new URLSearchParams(window.location.search);
            if(params.has('product')) { window.openProductFullLanding(params.get('product')); isDeepLinkProcessed = true; }
            else if (params.has('category')) { window.goToCategory(params.get('category')); isDeepLinkProcessed = true; }
            else if (params.has('page')) { window.showSection('custom', params.get('page')); isDeepLinkProcessed = true; }
        };
        
        // --- LOGICA CARRITO E-COMMERCE ---
        
        window.toggleCart = (forceOpen = false) => {
            const dr = document.getElementById('cart-drawer');
            const ov = document.getElementById('cart-overlay');
            if (forceOpen === true || !dr.classList.contains('cart-open')) {
                dr.classList.add('cart-open');
                ov.classList.remove('hidden');
                setTimeout(() => ov.classList.remove('opacity-0'), 10);
            } else {
                dr.classList.remove('cart-open');
                ov.classList.add('opacity-0');
                setTimeout(() => ov.classList.add('hidden'), 300);
            }
        };

        window.updateCartUI = () => {
            const count = cart.reduce((s, i) => s + i.qty, 0);
            const badge = document.getElementById('cart-count-badge');
            badge.innerText = count;
            if(count > 0) badge.classList.remove('scale-0'); else badge.classList.add('scale-0');
            
            const cont = document.getElementById('cart-items-container');
            const totalEl = document.getElementById('cart-total-price');
            const btn = document.getElementById('btn-go-checkout');

            if(cart.length === 0) {
                cont.innerHTML = `<div class="text-center py-10"><span class="text-4xl block mb-2">🛒</span><p class="text-[10px] font-black uppercase text-slate-400 tracking-widest">Tu carrito está vacío</p></div>`;
                totalEl.innerText = "0"; btn.disabled = true;
                return;
            }

            let total = 0;
            cont.innerHTML = cart.map((item, index) => {
                total += item.price * item.qty;
                return `
                <div class="bg-white p-3 rounded-2xl flex gap-3 shadow-sm border border-slate-100 items-center animate-in slide-in-from-right duration-300">
                    <img src="${item.image}" class="w-16 h-16 rounded-xl object-cover shrink-0 bg-slate-50">
                    <div class="flex-grow flex flex-col justify-between">
                        <div class="flex justify-between items-start">
                            <div>
                                <h4 class="font-black text-[10px] lg:text-xs uppercase leading-tight line-clamp-1 text-slate-800">${item.name}</h4>
                                <span class="text-[8px] lg:text-[9px] font-bold text-slate-400 uppercase tracking-widest bg-slate-100 px-1.5 py-0.5 rounded mt-0.5 inline-block border border-slate-200">${item.variant}</span>
                            </div>
                            <button onclick="window.removeFromCart(${index})" class="text-red-400 hover:text-red-500 p-1 shrink-0"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button>
                        </div>
                        <div class="flex justify-between items-end mt-2">
                            <span class="font-black text-comfort text-sm italic leading-none">${item.price} <span class="text-[8px] text-slate-400">Bs.</span></span>
                            <div class="flex items-center gap-2 bg-slate-50 rounded-lg p-0.5 border border-slate-100">
                                <button onclick="window.updateCartQty(${index}, -1)" class="w-6 h-6 flex items-center justify-center text-slate-500 font-bold hover:bg-white rounded-md shadow-sm transition">-</button>
                                <span class="text-[10px] font-black w-4 text-center">${item.qty}</span>
                                <button onclick="window.updateCartQty(${index}, 1)" class="w-6 h-6 flex items-center justify-center text-slate-500 font-bold hover:bg-white rounded-md shadow-sm transition">+</button>
                            </div>
                        </div>
                    </div>
                </div>`;
            }).join('');
            
            totalEl.innerText = total;
            btn.disabled = false;
        };

        window.addToCart = (productId) => {
            const p = products.find(x => x.id === productId); if(!p) return;
            const actPromo = getActivePromo(p.promoId);
            // Validar variante
            let variantToSave = 'Única';
            if(p.variants) {
                if(!window.currentSelectedVariant) {
                    window.showToast("⚠️ Selecciona una talla o variante antes de añadir.");
                    return;
                }
                variantToSave = window.currentSelectedVariant;
            }

            const finalPrice = p.price; // O lógica de promo si existiera descuento directo
            const existing = cart.find(x => x.productId === productId && x.variant === variantToSave);
            
            if(existing) existing.qty++;
            else {
                cart.push({
                    id: Math.random().toString(36).substr(2,9),
                    productId: p.id,
                    name: p.name,
                    sku: p.sku || 'N/A',
                    price: finalPrice,
                    image: getImgArray(p.image)[0] || '',
                    variant: variantToSave,
                    qty: 1
                });
            }
            window.updateCartUI();
            window.showToast("🛒 Añadido al carrito");
            window.toggleCart(true); // Abre el drawer
        };

        window.removeFromCart = (index) => { cart.splice(index, 1); window.updateCartUI(); };
        window.updateCartQty = (index, delta) => {
            cart[index].qty += delta;
            if(cart[index].qty <= 0) cart.splice(index, 1);
            window.updateCartUI();
        };

        window.selectVariantUI = (pid, variant) => {
            window.currentSelectedVariant = variant;
            document.querySelectorAll(`.var-btn-${pid}`).forEach(b => {
                b.classList.remove('bg-blue-600', 'text-white', 'border-blue-600', 'shadow-md');
                b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
            });
            const btn = document.getElementById(`var-btn-${pid}-${variant.replace(/\s+/g,'')}`);
            if(btn) {
                btn.classList.add('bg-blue-600', 'text-white', 'border-blue-600', 'shadow-md');
                btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
            }
        };

        // --- CHECKOUT ---
        window.goToCheckout = () => {
            if(cart.length === 0) return;
            window.toggleCart(); // Cerrar drawer
            window.renderCheckoutSummary();
            window.showSection('checkout');
        };

        window.renderCheckoutSummary = () => {
            const cont = document.getElementById('checkout-summary-items');
            let total = 0;
            cont.innerHTML = cart.map(i => {
                total += i.price * i.qty;
                return `<div class="flex justify-between items-center bg-white p-2.5 rounded-xl border border-slate-100"><div class="flex items-center gap-2.5"><div class="relative"><img src="${i.image}" class="w-10 h-10 rounded-lg object-cover bg-slate-50"><span class="absolute -top-1 -right-1 bg-slate-800 text-white text-[7px] font-black w-3.5 h-3.5 flex items-center justify-center rounded-full">${i.qty}</span></div><div><p class="text-[9px] font-black uppercase text-slate-800 line-clamp-1 leading-tight">${i.name}</p><p class="text-[7px] text-slate-400 font-bold uppercase tracking-widest">${i.variant}</p></div></div><span class="text-[10px] font-black italic text-comfort">${i.price * i.qty} Bs.</span></div>`;
            }).join('');
            document.getElementById('checkout-total').innerText = total;
        };

        // Modificado para ocultar Efectivo y forzar QR si no es Santa Cruz
        window.handleCityChange = () => {
            const citySel = document.getElementById('co-city');
            const otherInp = document.getElementById('co-city-other');
            const labelEfectivo = document.getElementById('pay-label-efectivo');
            const radioQR = document.getElementById('pay-radio-qr');
            const payContainer = document.getElementById('payment-methods-container');

            if(citySel.value === 'Otro Lugar') {
                otherInp.classList.remove('hidden'); otherInp.required = true;
            } else {
                otherInp.classList.add('hidden'); otherInp.required = false;
            }

            // Lógica de métodos de pago dinámicos
            if(citySel.value === 'Santa Cruz') {
                labelEfectivo.style.display = 'block';
                payContainer.classList.add('grid-cols-2');
                payContainer.classList.remove('grid-cols-1');
            } else {
                labelEfectivo.style.display = 'none';
                radioQR.checked = true; // Forzar selección a QR
                payContainer.classList.remove('grid-cols-2');
                payContainer.classList.add('grid-cols-1');
            }
        };

        window.processCheckout = async (e) => {
            e.preventDefault();
            if(cart.length === 0) { window.showToast("Carrito vacío"); return; }
            
            const form = document.getElementById('checkout-form');
            if(!form.checkValidity()) { form.reportValidity(); return; }

            const name = document.getElementById('co-name').value.trim();
            const phone = document.getElementById('co-phone').value.trim();
            let city = document.getElementById('co-city').value;
            if(city === 'Otro Lugar') city = document.getElementById('co-city-other').value.trim();
            const address = document.getElementById('co-address').value.trim();
            const payment = document.querySelector('input[name="co-payment"]:checked').value;
            const total = cart.reduce((s, i) => s + (i.price * i.qty), 0);
            
            const btn = e.target;
            const originalText = btn.innerHTML;
            btn.innerHTML = `<span class="animate-spin mr-2">⏳</span> Procesando...`;
            btn.disabled = true;

            try {
                const orderData = {
                    items: JSON.stringify(cart), total, name, phone, city, address, payment,
                    status: 'Recibido', sellerId: '', createdAt: new Date().toISOString()
                };

                // Guardar Pedido
                await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'orders'), orderData);
                
                // Upsert Cliente (por teléfono simple)
                const existCust = customers.find(c => c.phone === phone);
                if(existCust) {
                    await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'customers', existCust.id), { lastOrderDate: orderData.createdAt, city, address, name });
                } else {
                    await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'customers'), { name, phone, city, address, firstOrderDate: orderData.createdAt, lastOrderDate: orderData.createdAt });
                }

                // Generar Mensaje WhatsApp
                let msg = `*Hola Vengo de ComfortLife, quiero realizar un pedido:*\n\n*🛍️ Productos:*\n`;
                cart.forEach(i => { msg += `\nProducto: ${i.name}\nSKU: ${i.sku}\nVariante: ${i.variant}\nCantidad: ${i.qty}\nPrecio: ${i.price} Bs.\n`; });
                msg += `\n*💰 Total:* ${total} Bs.\n\n*👤 Datos del cliente:*\nNombre: ${name}\nTeléfono: ${phone}\nCiudad: ${city}\nDirección: ${address || 'No especificada'}\n\n*💳 Método de pago:* ${payment}\n`;
                
                // Reset y Redirigir
                cart = []; window.updateCartUI(); form.reset(); window.handleCityChange();
                window.showSection('home');
                window.open(`https://wa.me/59170099233?text=${encodeURIComponent(msg)}`, '_blank');
            } catch (err) {
                console.error(err);
                window.showToast("Error al procesar el pedido ❌");
            } finally {
                btn.innerHTML = originalText; btn.disabled = false;
            }
        };

        // --- FIN LOGICA ECOMMERCE ---

        function getActivePromo(promoId) {
            if(!promoId) return null;
            return promos.find(x => x.id === promoId) || null;
        }

        function updateCountdowns() {
            document.querySelectorAll('.cl-countdown').forEach(el => {
                const diff = new Date(el.dataset.end).getTime() - new Date().getTime();
                if (diff <= 0) { el.innerText = "FINALIZADO"; return; }
                const d = Math.floor(diff / (1000 * 60 * 60 * 24));
                const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const s = Math.floor((diff % (1000 * 60)) / 1000);
                el.innerText = `${d>0?d+'d ':''}${h.toString().padStart(2,'0')}h ${m.toString().padStart(2,'0')}m ${s.toString().padStart(2,'0')}s`;
            });
        }
        setInterval(updateCountdowns, 1000);

        function buildFaqHtml(faqId) {
            if (!faqId) return "";
            const faqData = faqs.find(f => f.id === faqId);
            if (!faqData || !faqData.questions) return "";
            let qList = []; try { qList = JSON.parse(faqData.questions); } catch(e) {}
            if (qList.length === 0) return "";
            let html = `<div class="mt-3 lg:mt-6 mb-4 lg:mb-8 bg-white border border-slate-100 rounded-[1.5rem] lg:rounded-3xl shadow-sm p-3 lg:p-6 italic text-left max-w-3xl mx-auto w-full"><h4 class="text-[9px] lg:text-xs font-black uppercase text-emerald-600 mb-2 tracking-widest border-b border-slate-50 pb-2 flex items-center gap-1.5"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Preguntas Frecuentes</h4><div class="flex flex-col">`;
            qList.forEach(item => {
                html += `<details class="group border-b border-slate-50 last:border-0 py-2"><summary class="flex justify-between items-center font-bold cursor-pointer list-none text-[10px] lg:text-sm text-slate-700 outline-none pr-2"><span class="leading-snug pr-3">${item.q}</span><span class="transition group-open:rotate-180 text-emerald-500 font-black shrink-0">▾</span></summary><div class="text-slate-500 text-[9px] lg:text-xs pt-2 animate-in fade-in leading-relaxed pr-4"><p>${item.a.replace(/\n/g, '<br>')}</p>${item.img ? `<img src="${item.img}" class="mt-2 rounded-xl max-h-32 w-full object-cover border shadow-sm">` : ''}</div></details>`;
            });
            html += `</div></div>`; return html;
        }

        function buildPolicyButtonsHtml(productId, policyId) {
            if(!policyId) return "";
            return `
