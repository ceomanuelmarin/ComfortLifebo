<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Comfort Life | Salud Integral Bolivia</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
        
        :root {
            --comfort-blue: #1e3a8a;
            --comfort-light: #f8fafc;
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--comfort-light);
            scroll-behavior: smooth;
        }

        .text-comfort { color: var(--comfort-blue); }
        .bg-comfort { background-color: var(--comfort-blue); }

        #mobile-drawer { transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .drawer-open { transform: translateX(0) !important; }
        
        .product-card { transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .product-card:hover { transform: translateY(-12px); box-shadow: 0 40px 60px -15px rgba(30, 58, 138, 0.15); }

        .admin-tab-active { color: var(--comfort-blue); border-bottom: 3px solid var(--comfort-blue); font-weight: 800; }
        .no-scrollbar::-webkit-scrollbar { display: none; }

        /* Carrusel Táctil Fluido */
        .img-carousel {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
        }
        .img-carousel::-webkit-scrollbar { display: none; }
        .img-carousel img {
            flex: 0 0 100%;
            scroll-snap-align: center;
            object-fit: cover;
        }

        /* Contenedor seguro para el iframe de la ficha técnica */
        .safe-iframe-wrapper {
            width: 100%;
            height: 800px;
            overflow: hidden;
            border-radius: 2rem;
            background: white;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
        }

        #safe-frame-container { 
            width: 100%; 
            height: 100%; 
            border: none; 
        }

        .pulse-img { animation: soft-pulse 4s infinite ease-in-out; }
        @keyframes soft-pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.03); } }

        /* Modal de Producto */
        #product-modal-container { transition: all 0.3s ease-out; }
        .modal-show { opacity: 1 !important; pointer-events: auto !important; transform: scale(1) !important; }
    </style>
</head>
<body class="text-slate-900">

    <nav class="sticky top-0 z-[100] bg-white/90 backdrop-blur-xl border-b border-slate-100 shadow-sm px-4 lg:px-8">
        <div class="max-w-7xl mx-auto h-20 flex justify-between items-center">
            <div class="flex items-center gap-3 cursor-pointer" onclick="showSection('home')">
                <div class="w-12 h-12 bg-comfort rounded-2xl flex items-center justify-center text-white font-black text-2xl shadow-lg">CL</div>
                <div class="leading-none text-left">
                    <span class="block font-black text-xl text-comfort uppercase tracking-tighter italic">ComfortLife</span>
                    <span class="text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em] mt-1 italic">BOLIVIA</span>
                </div>
            </div>

            <div class="hidden lg:flex items-center gap-8 font-black text-[10px] uppercase tracking-widest text-slate-500" id="pc-nav"></div>

            <div class="flex items-center gap-4">
                <button onclick="openAuthModal()" class="hidden md:block px-6 py-2.5 rounded-full border-2 border-slate-100 text-[10px] font-black uppercase hover:border-comfort transition">Admin</button>
                <button onclick="toggleDrawer()" class="lg:hidden p-3 bg-slate-100 rounded-2xl text-comfort">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16m-7 6h7"/></svg>
                </button>
            </div>
        </div>
    </nav>

    <div id="drawer-overlay" onclick="toggleDrawer()" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[150] opacity-0 pointer-events-none transition-opacity duration-300"></div>
    <div id="mobile-drawer" class="fixed top-0 right-0 h-full w-[320px] bg-white z-[200] shadow-2xl translate-x-full overflow-y-auto">
        <div class="p-8 border-b border-slate-50 flex justify-between items-center sticky top-0 bg-white">
            <span class="font-black text-comfort italic uppercase text-lg text-left">ComfortLife</span>
            <button onclick="toggleDrawer()" class="text-slate-300 hover:text-comfort p-2">✕</button>
        </div>
        <div class="p-8 space-y-10" id="mobile-nav-dynamic"></div>
    </div>

    <section id="section-home" class="animate-in fade-in duration-500">
        <div class="max-w-7xl mx-auto px-6 py-12 lg:py-24 grid lg:grid-cols-2 gap-16 items-center text-left">
            <div class="space-y-8 italic">
                <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter leading-none text-slate-900">Salud en <span class="text-blue-600">Cada Paso</span></h1>
                <p class="text-lg font-medium text-slate-500 leading-relaxed max-w-lg italic">Expertos en Bolivia en soluciones ortopédicas avanzadas diseñadas para el alivio plantar y corrección postural.</p>
                <div class="flex flex-wrap gap-4 pt-4">
                    <button onclick="showSection('catalog')" class="px-10 py-5 bg-comfort text-white rounded-full font-black uppercase text-[10px] tracking-widest shadow-2xl hover:scale-105 transition-all">Explorar Catálogo</button>
                    <button onclick="document.getElementById('home-ai-section').scrollIntoView({behavior: 'smooth'})" class="px-10 py-5 border-2 border-blue-100 text-blue-600 rounded-full font-black uppercase text-[10px] tracking-widest hover:bg-blue-50 transition-all flex items-center gap-3 italic">Pregunta a la IA ✨</button>
                </div>
            </div>
            <div class="relative flex justify-center lg:justify-end">
                <div class="relative group">
                    <div class="absolute inset-0 bg-blue-100 rounded-[4rem] blur-3xl opacity-30 group-hover:opacity-50 transition-all"></div>
                    <img src="https://images.unsplash.com/photo-1519415510236-85592ac7530b?auto=format&fit=crop&q=80&w=800" class="relative w-full max-w-md rounded-[3rem] shadow-2xl border-8 border-white pulse-img">
                </div>
            </div>
        </div>

        <div id="home-ai-section" class="max-w-4xl mx-auto px-6 py-8">
            <div class="bg-white rounded-[2rem] shadow-xl border border-slate-100 overflow-hidden flex flex-col md:flex-row italic text-left">
                <div class="bg-comfort text-white p-8 md:w-1/3 flex flex-col justify-center">
                    <span class="text-3xl mb-3">✨</span>
                    <h3 class="text-2xl font-black uppercase tracking-tighter mb-2">Asistente IA</h3>
                    <p class="text-blue-100 font-medium text-[11px] leading-relaxed">Dime tus síntomas o lo que buscas. Te daré respuestas breves y los mejores productos.</p>
                </div>
                <div class="p-6 md:p-8 md:w-2/3 flex flex-col h-[380px] bg-slate-50/50">
                    <div id="ai-messages-embedded" class="flex-grow overflow-y-auto space-y-4 pr-3 no-scrollbar flex flex-col">
                        <div class="bg-white p-5 rounded-2xl rounded-tl-none border border-slate-100 shadow-sm text-xs text-slate-600 w-5/6 self-start leading-relaxed">
                            ¡Hola! Soy tu asesor virtual. ¿En qué te puedo ayudar hoy de forma rápida?
                        </div>
                    </div>
                    <div class="flex gap-2 bg-white p-2 rounded-2xl shadow-sm border border-slate-100 mt-4">
                        <input type="text" id="ai-input-embedded" class="flex-grow px-4 bg-transparent text-xs outline-none font-medium" placeholder="Escribe aquí tu consulta..." onkeypress="if(event.key === 'Enter') window.askAI('embedded')">
                        <button onclick="window.askAI('embedded')" class="w-10 h-10 bg-comfort text-white rounded-xl shadow-md flex items-center justify-center hover:scale-105 transition-transform shrink-0">
                            ➤
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="py-24 bg-white">
            <div class="max-w-7xl mx-auto px-6">
                <div class="mb-16 text-center italic">
                    <h2 class="text-4xl font-black text-slate-900 uppercase tracking-tighter">Líneas de Cuidado</h2>
                    <div class="w-20 h-1.5 bg-comfort mx-auto mt-4 rounded-full"></div>
                </div>
                <div id="category-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10"></div>
            </div>
        </div>
    </section>

    <section id="section-catalog" class="hidden py-24 px-6 max-w-7xl mx-auto">
        <div class="flex flex-col lg:flex-row justify-between items-center gap-10 mb-16 italic text-left">
            <div class="space-y-2 text-center lg:text-left">
                <h2 class="text-6xl font-black text-slate-900 uppercase tracking-tighter leading-none">Catálogo</h2>
                <p class="text-slate-400 font-bold uppercase tracking-[0.3em] text-[9px]">Encuentra tu solución</p>
            </div>
            <div class="w-full lg:w-96 relative">
                <input type="text" id="catalog-search" oninput="window.filterCatalogUI()" placeholder="🔍 Buscar producto..." class="w-full p-5 bg-white border border-slate-100 rounded-3xl text-sm italic outline-none shadow-sm focus:ring-4 focus:ring-blue-50">
            </div>
        </div>
        <div id="filter-bar" class="flex flex-wrap gap-2 justify-center mb-16 italic"></div>
        <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12"></div>
    </section>

    <section id="section-custom" class="hidden py-24 px-6 max-w-7xl mx-auto animate-in slide-in-from-right duration-500 italic text-left">
        <button onclick="showSection('catalog')" class="mb-12 flex items-center gap-3 text-slate-400 font-black uppercase text-[10px] hover:text-comfort transition group">
            <span class="group-hover:-translate-x-1 transition-transform">←</span> Volver al catálogo
        </button>
        <div id="custom-renderer" class="prose prose-slate max-w-none"></div>
        <div id="custom-wa-container" class="hidden mt-20 p-12 bg-slate-50 rounded-[3rem] border border-slate-100 text-center space-y-6 max-w-3xl mx-auto">
            <h3 class="font-black text-3xl uppercase text-comfort">¿Listo para ordenar?</h3>
            <button id="custom-wa-btn-full" class="mx-auto bg-[#25D366] text-white px-12 py-6 rounded-3xl font-black uppercase shadow-2xl flex items-center gap-4 hover:scale-105 transition text-xs tracking-widest">Pedido WhatsApp</button>
        </div>
    </section>

    <div id="product-modal-container" class="fixed inset-0 z-[350] bg-slate-900/80 backdrop-blur-md opacity-0 pointer-events-none flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-4xl rounded-[3.5rem] shadow-2xl overflow-hidden transform scale-90 transition-all duration-300 relative">
            <button onclick="closeProductModal()" class="absolute top-6 right-8 text-slate-300 hover:text-comfort text-2xl z-50">✕</button>
            <div id="modal-content" class="p-8 lg:p-12 italic text-left"></div>
        </div>
    </div>

    <!-- MODAL PLANTILLA LOGÍSTICA -->
    <div id="template-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-xl z-[400] hidden items-center justify-center p-4">
        <div class="bg-white w-full max-w-2xl rounded-[3.5rem] shadow-2xl overflow-hidden animate-in zoom-in duration-300 italic text-left">
            <div class="p-8 border-b flex justify-between items-center bg-slate-50/50">
                <h3 class="font-black text-2xl text-comfort uppercase tracking-tighter">Plantilla Logística</h3>
                <button onclick="window.closeTemplateModal()" class="text-slate-300 text-3xl">✕</button>
            </div>
            <form id="template-form" class="p-10 space-y-6">
                <input type="hidden" id="temp-id">
                <input type="text" id="temp-name" required placeholder="Nombre (Ej: Envíos Nacionales)" class="w-full p-5 bg-slate-50 rounded-2xl border outline-none font-bold italic text-left">
                <div class="bg-blue-50/50 p-8 rounded-[2.5rem] border border-blue-100 space-y-4">
                    <label class="text-[10px] font-black uppercase text-blue-600 tracking-widest">Bloques de Información (Garantía, Envíos, etc)</label>
                    <div id="template-blocks-container" class="space-y-2"></div>
                    <button type="button" onclick="window.addTemplateBlock()" class="w-full py-3 bg-white border shadow-sm rounded-xl font-black text-[10px] text-blue-600 uppercase">+ Añadir Bloque</button>
                </div>
                <button type="submit" class="w-full py-6 bg-comfort text-white rounded-3xl font-black uppercase tracking-widest shadow-xl">Guardar Plantilla</button>
            </form>
        </div>
    </div>

    <!-- NUEVO: MODAL DE CONFIRMACIÓN DE BORRADO -->
    <div id="confirm-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-xl z-[600] hidden items-center justify-center p-4">
        <div class="bg-white rounded-[2.5rem] p-10 max-w-sm w-full text-center shadow-2xl animate-in zoom-in duration-200 italic">
            <div class="w-20 h-20 bg-red-50 text-red-500 rounded-[2rem] flex items-center justify-center mx-auto mb-6 text-4xl shadow-inner border border-red-100">⚠️</div>
            <h3 class="text-2xl font-black text-slate-900 mb-3 uppercase tracking-tighter">¿Estás seguro?</h3>
            <p class="text-[11px] font-bold text-slate-400 mb-8 uppercase tracking-widest leading-relaxed">Esta acción es irreversible y eliminará el dato permanentemente.</p>
            <div class="flex gap-4">
                <button onclick="window.closeConfirmModal()" class="flex-1 py-4 bg-slate-50 text-slate-500 border border-slate-200 rounded-2xl font-black uppercase text-[10px] tracking-widest hover:bg-slate-100 transition">Cancelar</button>
                <button id="confirm-btn-action" class="flex-1 py-4 bg-red-500 text-white rounded-2xl font-black uppercase text-[10px] tracking-widest shadow-xl shadow-red-200 hover:bg-red-600 transition">Eliminar</button>
            </div>
        </div>
    </div>

    <div id="view-admin" class="hidden min-h-screen py-24 px-6 max-w-7xl mx-auto animate-in fade-in duration-300 italic text-left">
        <div class="flex flex-wrap border-b-2 border-slate-50 mb-16 gap-10 no-scrollbar overflow-x-auto">
            <button onclick="setAdminTab('inventory')" id="tab-inventory" class="pb-6 text-[10px] font-black uppercase tracking-widest admin-tab-active">Inventario</button>
            <button onclick="setAdminTab('attributes')" id="tab-attributes" class="pb-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Atributos</button>
            <button onclick="setAdminTab('templates')" id="tab-templates" class="pb-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Logística</button>
            <button onclick="setAdminTab('pages')" id="tab-pages" class="pb-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Páginas</button>
            <button onclick="setAdminTab('ai-config')" id="tab-ai-config" class="pb-6 text-[10px] font-black uppercase tracking-widest text-slate-400">Config IA</button>
            <button onclick="logout()" class="pb-6 text-[10px] font-black uppercase tracking-widest text-red-500 ml-auto">Salir</button>
        </div>

        <div id="admin-inventory" class="admin-pane space-y-8">
            <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                <h2 class="text-3xl font-black uppercase text-comfort">Stock Maestro <span class="text-xs text-slate-400 font-bold ml-2">(Versión 2.6 - Fix Borrado)</span></h2>
                <div class="flex flex-wrap gap-4 w-full md:w-auto">
                    <input type="text" id="admin-kw" oninput="window.renderAdminProducts()" placeholder="Buscar producto..." class="p-4 bg-slate-50 border rounded-2xl text-xs outline-none flex-grow italic">
                    <select id="admin-filter-cat" onchange="window.renderAdminProducts()" class="p-4 bg-slate-50 border rounded-2xl text-xs admin-cat-select font-bold italic"></select>
                    <select id="admin-filter-badge" onchange="window.renderAdminProducts()" class="p-4 bg-slate-50 border rounded-2xl text-xs admin-badge-select font-bold italic"></select>
                    <button onclick="window.seedDatabase()" class="bg-blue-50 text-blue-600 px-6 py-4 rounded-2xl font-black text-[10px] uppercase shadow-sm tracking-widest hover:bg-blue-100 transition">Carga Masiva</button>
                    <button onclick="openEditModal('prod')" class="bg-comfort text-white px-8 py-4 rounded-2xl font-black text-xs uppercase shadow-xl tracking-widest">Nuevo</button>
                </div>
            </div>
            <div class="bg-white rounded-[2rem] border overflow-hidden shadow-sm">
                <table class="w-full text-left italic">
                    <thead class="bg-slate-50 border-b italic">
                        <tr class="text-[9px] font-black uppercase text-slate-400">
                            <th class="px-8 py-5">Producto / Tallas</th>
                            <th class="px-8 py-5 text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="admin-products-list"></tbody>
                </table>
            </div>
        </div>

        <div id="admin-attributes" class="admin-pane hidden space-y-12">
            <div class="grid lg:grid-cols-2 gap-12">
                <div class="bg-white p-10 rounded-[2rem] border shadow-sm space-y-6">
                    <h3 class="text-xl font-black uppercase text-comfort italic text-left">Categorías</h3>
                    <div class="flex flex-col gap-3">
                        <input type="hidden" id="edit-cat-id">
                        <div class="flex gap-2">
                            <input type="text" id="new-cat-name" placeholder="Nombre" class="flex-grow p-4 bg-slate-50 border rounded-2xl outline-none text-sm font-bold italic">
                            <input type="color" id="new-cat-color" value="#1e3a8a" class="w-14 h-14 p-1 bg-white border rounded-2xl cursor-pointer shadow-inner">
                        </div>
                        <select id="new-cat-template" class="p-4 bg-slate-50 border rounded-2xl outline-none text-xs font-bold italic admin-template-select">
                            <option value="">Sin Plantilla Logística</option>
                        </select>
                        <button onclick="window.addAttribute('categories')" class="w-full py-4 bg-comfort text-white rounded-2xl font-black uppercase text-[10px] tracking-widest italic mt-2">Guardar Categoría</button>
                    </div>
                    <div id="list-categories" class="space-y-2 mt-4"></div>
                </div>
                <div class="bg-white p-10 rounded-[2rem] border shadow-sm space-y-6">
                    <h3 class="text-xl font-black uppercase text-comfort italic text-left">Etiquetas / Badges</h3>
                    <div class="flex flex-col gap-3">
                        <input type="hidden" id="edit-badge-id">
                        <div class="flex gap-2">
                            <input type="text" id="new-badge-name" placeholder="Nombre (Ej: Oferta)" class="flex-grow p-4 bg-slate-50 border rounded-2xl outline-none text-sm font-bold italic">
                            <input type="color" id="new-badge-color" value="#1e3a8a" class="w-14 h-14 p-1 bg-white border rounded-2xl cursor-pointer shadow-inner">
                        </div>
                        <button onclick="window.addAttribute('badges')" class="w-full py-4 bg-comfort text-white rounded-2xl font-black uppercase text-[10px] tracking-widest italic mt-2">Guardar Etiqueta</button>
                    </div>
                    <div id="list-badges" class="space-y-2 mt-4"></div>
                </div>
            </div>
        </div>

        <div id="admin-templates" class="admin-pane hidden space-y-8">
            <div class="flex justify-between items-center italic">
                <h3 class="text-2xl font-black uppercase tracking-tighter">Plantillas de Logística</h3>
                <button onclick="window.openTemplateModal()" class="bg-indigo-600 text-white px-8 py-4 rounded-2xl font-black text-xs uppercase shadow-xl tracking-widest">Nueva Plantilla</button>
            </div>
            <p class="text-slate-500 text-sm">Crea plantillas con información de envíos y garantías. Luego, asígnalas a tus categorías para que todos sus productos las muestren automáticamente.</p>
            <div id="admin-templates-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
        </div>

        <div id="admin-pages" class="admin-pane hidden space-y-8">
            <div class="flex justify-between items-center italic">
                <h3 class="text-2xl font-black uppercase tracking-tighter">Editor de Páginas</h3>
                <button onclick="openEditModal('page')" class="bg-indigo-600 text-white px-8 py-4 rounded-2xl font-black text-xs uppercase shadow-xl tracking-widest">Nueva Página</button>
            </div>
            <div id="admin-pages-list" class="space-y-4"></div>
        </div>

        <div id="admin-ai-config" class="admin-pane hidden max-w-2xl mx-auto italic space-y-8 text-center">
            <h3 class="font-black text-xs uppercase tracking-widest text-comfort">Personalidad IA</h3>
            <textarea id="ai-prompt-config" class="w-full p-6 bg-slate-50 border rounded-3xl h-64 outline-none text-xs italic" placeholder="Instrucciones..."></textarea>
            <button onclick="window.saveAIConfig()" class="w-full py-5 bg-comfort text-white rounded-3xl font-black uppercase text-[10px] shadow-xl tracking-widest mt-4">Actualizar Gemini</button>
        </div>
    </div>

    <!-- MODAL DE EDICIÓN MÁS AMPLIO Y COMPACTO -->
    <div id="edit-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-xl z-[400] hidden items-center justify-center p-4">
        <div class="bg-white w-full max-w-5xl rounded-[2.5rem] shadow-2xl overflow-hidden animate-in zoom-in duration-300 italic text-left flex flex-col max-h-[90vh]">
            <div class="p-6 md:p-8 border-b flex justify-between items-center bg-slate-50/50 shrink-0">
                <h3 id="edit-modal-title" class="font-black text-2xl text-comfort uppercase tracking-tighter">Editor Maestro</h3>
                <button onclick="closeEditModal()" class="text-slate-300 hover:text-comfort transition text-3xl">✕</button>
            </div>
            <div class="p-6 md:p-8 overflow-y-auto no-scrollbar flex-grow" id="edit-form-container"></div>
        </div>
    </div>

    <div id="auth-modal" class="fixed inset-0 bg-blue-900/60 backdrop-blur-2xl z-[450] hidden items-center justify-center p-4">
        <div class="bg-white w-full max-w-md rounded-[3rem] shadow-2xl p-16 text-center italic">
            <h3 class="text-3xl font-black text-slate-900 mb-10 uppercase tracking-tighter leading-none">Consola Maestro</h3>
            <input type="password" id="auth-pass" placeholder="••••••••" class="w-full p-6 bg-slate-50 border-2 border-slate-100 rounded-3xl outline-none font-black text-center text-3xl tracking-[0.4em] shadow-inner">
            <button onclick="window.handleLogin()" class="w-full py-6 bg-comfort text-white rounded-3xl font-black uppercase shadow-2xl mt-10 tracking-widest">Entrar</button>
            <button onclick="closeAuthModal()" class="mt-8 text-slate-400 font-bold uppercase text-[10px] tracking-widest cursor-pointer">Cerrar</button>
        </div>
    </div>

    <div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 px-12 py-5 bg-slate-900 text-white rounded-full text-[10px] font-black uppercase translate-y-28 transition-transform z-[500] italic"></div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getFirestore, collection, doc, setDoc, getDoc, addDoc, onSnapshot, deleteDoc, updateDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";

        // APP ID Versión 2.6 - Admin Compacto + IA + Fix Borrado
