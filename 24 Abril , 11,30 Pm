<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <!-- BLOQUEO DE ZOOM: maximum-scale=1.0 y user-scalable=no -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Comfort Life | Salud Integral Bolivia</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
        
        :root {
            --comfort-blue: #1e3a8a;
            --comfort-light: #f8fafc;
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--comfort-light);
            scroll-behavior: smooth;
            /* Prevención de selección de texto a nivel global para mayor sensación de App */
            -webkit-user-select: none;
            user-select: none;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* PERMITIR SELECCIÓN EN INPUTS Y TEXTAREAS */
        input, textarea {
            -webkit-user-select: text;
            user-select: text;
        }

        /* PROTECCIÓN DE IMÁGENES: Evita arrastre y menú contextual en móviles */
        img {
            -webkit-user-drag: none;
            -khtml-user-drag: none;
            -moz-user-drag: none;
            -o-user-drag: none;
            user-drag: none;
            -webkit-touch-callout: none;
        }

        .text-comfort { color: var(--comfort-blue); }
        .bg-comfort { background-color: var(--comfort-blue); }

        #mobile-drawer { transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .drawer-open { transform: translateX(0) !important; }
        
        .product-card { transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .product-card:hover { transform: translateY(-12px); box-shadow: 0 40px 60px -15px rgba(30, 58, 138, 0.15); }

        .admin-tab-active { color: var(--comfort-blue); border-bottom: 3px solid var(--comfort-blue); font-weight: 800; }
        .no-scrollbar::-webkit-scrollbar { display: none; }

        details summary::-webkit-details-marker { display: none; }

        .img-carousel {
            display: flex;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
        }
        .img-carousel::-webkit-scrollbar { display: none; }
        .img-carousel img {
            flex: 0 0 100%;
            scroll-snap-align: center;
            object-fit: cover;
        }

        .safe-iframe-wrapper {
            width: 100%;
            height: 800px;
            overflow: hidden;
            border-radius: 2rem;
            background: white;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
        }

        #safe-frame-container { 
            width: 100%; 
            height: 100%; 
            border: none; 
        }

        .pulse-img { animation: soft-pulse 4s infinite ease-in-out; }
        @keyframes soft-pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.03); } }

        #product-modal-container { transition: all 0.3s ease-out; }
        .modal-show { opacity: 1 !important; pointer-events: auto !important; transform: scale(1) !important; }
        
        /* Flex grow para empujar el footer abajo */
        main { flex-grow: 1; }
    </style>
</head>
<body class="text-slate-900" oncontextmenu="return false;">

    <nav class="sticky top-0 z-[100] bg-white/90 backdrop-blur-xl border-b border-slate-100 shadow-sm px-4 lg:px-8">
        <div class="max-w-7xl mx-auto h-16 lg:h-20 flex justify-between items-center">
            <div class="flex items-center gap-3 cursor-pointer" onclick="showSection('home')">
                <div class="w-10 h-10 lg:w-12 lg:h-12 bg-comfort rounded-xl lg:rounded-2xl flex items-center justify-center text-white font-black text-xl lg:text-2xl shadow-lg">CL</div>
                <div class="leading-none text-left">
                    <span class="block font-black text-lg lg:text-xl text-comfort uppercase tracking-tighter italic">ComfortLife</span>
                    <span class="text-[8px] lg:text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em] mt-1 italic">BOLIVIA</span>
                </div>
            </div>

            <div class="hidden lg:flex items-center gap-8 font-black text-[10px] uppercase tracking-widest text-slate-500" id="pc-nav"></div>

            <div class="flex items-center gap-4">
                <button onclick="openAuthModal()" class="hidden md:block px-6 py-2.5 rounded-full border-2 border-slate-100 text-[10px] font-black uppercase hover:border-comfort transition">Admin</button>
                <button onclick="toggleDrawer()" class="lg:hidden p-2 bg-slate-100 rounded-xl text-comfort">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16m-7 6h7"/></svg>
                </button>
            </div>
        </div>
    </nav>

    <div id="drawer-overlay" onclick="toggleDrawer()" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-[150] opacity-0 pointer-events-none hidden transition-opacity duration-300"></div>
    <div id="mobile-drawer" class="fixed top-0 right-0 h-full w-[320px] bg-white z-[200] shadow-2xl translate-x-full overflow-y-auto">
        <div class="p-6 lg:p-8 border-b border-slate-50 flex justify-between items-center sticky top-0 bg-white">
            <span class="font-black text-comfort italic uppercase text-lg text-left">ComfortLife</span>
            <button onclick="toggleDrawer()" class="text-slate-300 hover:text-comfort p-2">✕</button>
        </div>
        <div class="p-6 lg:p-8 space-y-10" id="mobile-nav-dynamic"></div>
    </div>

    <main>
        <section id="section-home" class="animate-in fade-in duration-500">
            <!-- HERO ESPACIOS REDUCIDOS -->
            <div class="max-w-7xl mx-auto px-4 lg:px-6 py-4 lg:py-10 grid lg:grid-cols-2 gap-4 lg:gap-10 items-center text-left">
                <div class="space-y-4 lg:space-y-6 italic">
                    <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter leading-none text-slate-900">Salud en <span class="text-blue-600">Cada Paso</span></h1>
                    <p class="text-sm lg:text-lg font-medium text-slate-500 leading-relaxed max-w-lg italic">Expertos en Bolivia en soluciones ortopédicas avanzadas diseñadas para el alivio plantar y corrección postural.</p>
                    <div class="flex flex-wrap gap-2 lg:gap-4 pt-2">
                        <button onclick="showSection('catalog')" class="px-6 py-3 lg:px-8 lg:py-4 bg-comfort text-white rounded-full font-black uppercase text-[9px] lg:text-[10px] tracking-widest shadow-xl hover:scale-105 transition-all">Explorar Catálogo</button>
                        <button onclick="document.getElementById('home-ai-section').scrollIntoView({behavior: 'smooth'})" class="px-6 py-3 lg:px-8 lg:py-4 border-2 border-blue-100 text-blue-600 rounded-full font-black uppercase text-[9px] lg:text-[10px] tracking-widest hover:bg-blue-50 transition-all flex items-center gap-2 italic">Asistente ComfortLife IA ✨</button>
                    </div>
                </div>
                <div class="relative flex justify-center lg:justify-end mt-4 lg:mt-0">
                    <div class="relative group">
                        <div class="absolute inset-0 bg-blue-100 rounded-[3rem] blur-2xl opacity-40 group-hover:opacity-60 transition-all"></div>
                        <img src="https://images.unsplash.com/photo-1519415510236-85592ac7530b?auto=format&fit=crop&q=80&w=600" class="relative w-full max-w-[280px] lg:max-w-md rounded-[2.5rem] shadow-2xl border-4 lg:border-8 border-white pulse-img object-cover">
                    </div>
                </div>
            </div>

            <!-- CÁPSULA IA COMPACTA -->
            <div id="home-ai-section" class="max-w-4xl mx-auto px-4 lg:px-6 py-2">
                <div class="bg-white rounded-[2rem] lg:rounded-full shadow-lg border border-slate-100 overflow-hidden flex flex-col lg:flex-row items-center p-2 lg:p-2.5 gap-2 italic">
                    <div class="bg-comfort text-white px-4 py-2 lg:py-3 rounded-full flex items-center justify-center gap-2 shrink-0 w-full lg:w-auto shadow-inner">
                        <span class="text-sm">✨</span>
                        <span class="font-black uppercase tracking-widest text-[9px]">Asistente IA</span>
                    </div>
                    <div class="flex-grow w-full flex flex-col">
                        <div id="ai-messages-embedded" class="max-h-[120px] overflow-y-auto px-2 py-1 text-[10px] space-y-1.5 no-scrollbar flex flex-col">
                            <div class="text-slate-500 font-bold self-start bg-slate-50 px-3 py-1.5 rounded-xl rounded-tl-none border border-slate-100 shadow-sm">¡Hola! ¿En qué te puedo ayudar hoy de forma rápida?</div>
                        </div>
                    </div>
                    <div class="flex gap-2 w-full lg:w-[320px] shrink-0 mt-1 lg:mt-0">
                        <input type="text" id="ai-input-embedded" class="flex-grow px-4 py-2.5 bg-slate-50 text-[10px] lg:text-xs font-bold outline-none rounded-full border border-slate-100 focus:border-blue-200 transition" placeholder="Escribe tu consulta..." onkeypress="if(event.key === 'Enter') window.askAI('embedded')">
                        <button onclick="window.askAI('embedded')" class="w-10 h-10 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center shrink-0 hover:bg-blue-100 transition shadow-sm font-black">➤</button>
                    </div>
                </div>
            </div>

            <!-- CATEGORÍAS REDUCIDAS -->
            <div class="py-6 lg:py-12 bg-white mt-4 rounded-t-[2.5rem] lg:rounded-t-[4rem]">
                <div class="max-w-7xl mx-auto px-4 lg:px-6">
                    <div class="mb-4 lg:mb-8 text-center italic">
                        <h2 class="text-3xl lg:text-4xl font-black text-slate-900 uppercase tracking-tighter">Líneas de Cuidado</h2>
                        <div class="w-16 h-1.5 bg-comfort mx-auto mt-3 rounded-full"></div>
                    </div>
                    <div id="category-grid" class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-2 lg:gap-8"></div>
                </div>
            </div>
        </section>

        <section id="section-catalog" class="hidden py-6 lg:py-10 px-4 lg:px-6 max-w-7xl mx-auto">
            <div class="flex flex-col lg:flex-row justify-between items-center gap-4 mb-6 italic text-left">
                <div class="space-y-1 text-center lg:text-left">
                    <h2 class="text-4xl lg:text-6xl font-black text-slate-900 uppercase tracking-tighter leading-none">Catálogo</h2>
                    <p class="text-slate-400 font-bold uppercase tracking-[0.3em] text-[8px] lg:text-[9px]">Encuentra tu solución</p>
                </div>
                <div class="w-full lg:w-96 relative">
                    <input type="text" id="catalog-search" oninput="window.filterCatalogUI()" placeholder="🔍 Buscar producto..." class="w-full p-3.5 lg:p-5 bg-white border border-slate-100 rounded-full text-xs italic outline-none shadow-sm focus:ring-4 focus:ring-blue-50">
                </div>
            </div>
            <div id="filter-bar" class="flex flex-wrap gap-1.5 lg:gap-2 justify-center mb-6 italic"></div>
            <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2 lg:gap-6"></div>
        </section>

        <section id="section-custom" class="hidden py-6 lg:py-10 px-4 lg:px-6 max-w-7xl mx-auto animate-in slide-in-from-right duration-500 italic text-left">
            <div class="flex justify-between items-center mb-4 lg:mb-6">
                <button onclick="showSection('catalog')" class="flex items-center gap-2 text-slate-400 font-black uppercase text-[9px] lg:text-[10px] hover:text-comfort transition group">
                    <span class="group-hover:-translate-x-1 transition-transform">←</span> Volver al catálogo
                </button>
                <button id="custom-share-btn" class="bg-slate-100 text-slate-600 px-3 py-2 rounded-xl text-[9px] font-black uppercase shadow-sm hover:bg-slate-200 transition flex items-center gap-1.5">🔗 Compartir</button>
            </div>
            <div id="custom-renderer" class="prose prose-slate max-w-none text-sm lg:text-base"></div>
        </section>

        <!-- Admin Panel, Modals, Toasts go here (unchanged logic structure) -->
        
        <div id="product-modal-container" class="fixed inset-0 z-[350] bg-slate-900/80 backdrop-blur-md opacity-0 pointer-events-none hidden flex items-center justify-center p-3 lg:p-6">
            <div class="bg-white w-full max-w-4xl rounded-[2rem] lg:rounded-[3.5rem] shadow-2xl overflow-hidden transform scale-90 transition-all duration-300 relative">
                <button onclick="closeProductModal()" class="absolute top-3 right-3 lg:top-4 lg:right-6 text-slate-300 hover:text-comfort text-2xl z-50 bg-white/50 backdrop-blur-sm rounded-full w-8 h-8 flex items-center justify-center">✕</button>
                <div id="modal-content" class="p-4 lg:p-12 italic text-left max-h-[90vh] overflow-y-auto no-scrollbar"></div>
            </div>
        </div>

        <!-- Modales de Plantillas (Logística, FAQ, Envíos/Pagos) -->
        <div id="template-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-xl z-[400] hidden flex items-center justify-center p-4">
            <div class="bg-white w-full max-w-2xl rounded-[2.5rem] lg:rounded-[3.5rem] shadow-2xl overflow-hidden animate-in zoom-in duration-300 italic text-left flex flex-col max-h-[90vh]">
                <div class="p-6 lg:p-8 border-b flex justify-between items-center bg-slate-50/50 shrink-0">
                    <h3 class="font-black text-xl lg:text-2xl text-comfort uppercase tracking-tighter">Plantilla Logística</h3>
                    <button onclick="window.closeTemplateModal()" class="text-slate-300 text-3xl">✕</button>
                </div>
                <form id="template-form" class="p-6 lg:p-10 space-y-6 overflow-y-auto no-scrollbar flex-grow">
                    <input type="hidden" id="temp-id">
                    <input type="text" id="temp-name" required placeholder="Nombre (Ej: Envíos Nacionales)" class="w-full p-4 bg-slate-50 rounded-2xl border outline-none font-bold italic text-left">
                    <div class="bg-blue-50/50 p-6 rounded-[2rem] border border-blue-100 space-y-4">
                        <label class="text-[10px] font-black uppercase text-blue-600 tracking-widest">Bloques de Información</label>
                        <div id="template-blocks-container" class="space-y-2"></div>
                        <button type="button" onclick="window.addTemplateBlock()" class="w-full py-3 bg-white border shadow-sm rounded-xl font-black text-[10px] text-blue-600 uppercase">+ Añadir Bloque</button>
                    </div>
                    <button type="submit" class="w-full py-5 bg-comfort text-white rounded-3xl font-black uppercase tracking-widest shadow-xl">Guardar Plantilla</button>
                </form>
            </div>
        </div>

        <div id="faq-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-xl z-[400] hidden flex items-center justify-center p-4">
            <div class="bg-white w-full max-w-3xl rounded-[2.5rem] shadow-2xl overflow-hidden animate-in zoom-in duration-300 italic text-left flex flex-col max-h-[90vh]">
                <div class="p-6 border-b flex justify-between items-center bg-emerald-50/50 shrink-0">
                    <h3 class="font-black text-xl text-emerald-700 uppercase tracking-tighter">Plantilla FAQ</h3>
                    <button onclick="window.closeFaqModal()" class="text-slate-300 hover:text-emerald-500 text-3xl transition">✕</button>
                </div>
                <form id="faq-form" class="p-6 space-y-6 overflow-y-auto no-scrollbar flex-grow">
                    <input type="hidden" id="faq-id">
                    <input type="text" id="faq-name" required placeholder="Nombre FAQ" class="w-full p-4 bg-slate-50 rounded-2xl border outline-none font-bold italic text-left">
                    <div class="bg-emerald-50/40 p-6 rounded-[2rem] border border-emerald-100 space-y-4">
                        <div id="faq-blocks-container" class="space-y-4"></div>
                        <button type="button" onclick="window.addFaqBlock()" class="w-full py-3 bg-white border shadow-sm rounded-xl font-black text-[10px] text-emerald-600 uppercase">+ Añadir Pregunta</button>
                    </div>
                    <button type="submit" class="w-full py-5 bg-emerald-600 text-white rounded-3xl font-black uppercase tracking-widest shadow-xl">Guardar FAQ</button>
                </form>
            </div>
        </div>

        <div id="admin-policy-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-xl z-[400] hidden flex items-center justify-center p-4">
            <div class="bg-white w-full max-w-2xl rounded-[2.5rem] shadow-2xl overflow-hidden animate-in zoom-in duration-300 italic text-left flex flex-col max-h-[90vh]">
                <div class="p-6 border-b flex justify-between items-center bg-indigo-50/50 shrink-0">
                    <h3 class="font-black text-xl text-indigo-700 uppercase tracking-tighter">Plantilla Envíos / Pagos</h3>
                    <button onclick="window.closeAdminPolicyModal()" class="text-slate-300 text-3xl transition">✕</button>
                </div>
                <form id="policy-form" class="p-6 space-y-6 overflow-y-auto no-scrollbar flex-grow">
                    <input type="hidden" id="pol-id">
                    <input type="text" id="pol-name" required placeholder="Nombre (Ej: Estándar Nacional)" class="w-full p-4 bg-slate-50 rounded-2xl border outline-none font-bold italic">
                    
                    <div class="bg-blue-50/40 p-5 rounded-2xl border border-blue-100 space-y-3">
                        <h4 class="text-[10px] font-black uppercase text-blue-600 tracking-widest">Envíos Bolivia</h4>
                        <textarea id="pol-ship-txt" class="w-full p-3 bg-white rounded-xl border outline-none text-xs italic min-h-[80px]"></textarea>
                        <div class="flex gap-2 items-center">
                            <input type="text" id="pol-ship-img" placeholder="URL Imagen..." class="flex-grow p-2.5 bg-white border rounded-lg text-[10px] italic outline-none">
                            <label class="bg-white text-blue-600 border border-blue-200 px-3 py-1.5 rounded-lg text-[9px] font-black uppercase cursor-pointer shadow-sm shrink-0">📷<input type="file" class="hidden" accept="image/*" onchange="window.handlePolicyImg(this, 'pol-ship-img')"></label>
                        </div>
                    </div>

                    <div class="bg-emerald-50/40 p-5 rounded-2xl border border-emerald-100 space-y-3">
                        <h4 class="text-[10px] font-black uppercase text-emerald-600 tracking-widest">Formas de Pago</h4>
                        <textarea id="pol-pay-txt" class="w-full p-3 bg-white rounded-xl border outline-none text-xs italic min-h-[80px]"></textarea>
                        <div class="flex gap-2 items-center">
                            <input type="text" id="pol-pay-img" placeholder="URL Imagen QR..." class="flex-grow p-2.5 bg-white border rounded-lg text-[10px] italic outline-none">
                            <label class="bg-white text-emerald-600 border border-emerald-200 px-3 py-1.5 rounded-lg text-[9px] font-black uppercase cursor-pointer shadow-sm shrink-0">📷<input type="file" class="hidden" accept="image/*" onchange="window.handlePolicyImg(this, 'pol-pay-img')"></label>
                        </div>
                    </div>

                    <button type="submit" class="w-full py-5 bg-indigo-600 text-white rounded-3xl font-black uppercase tracking-widest shadow-xl">Guardar</button>
                </form>
            </div>
        </div>

        <div id="confirm-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-xl z-[600] hidden flex items-center justify-center p-4">
            <div class="bg-white rounded-[2.5rem] p-8 max-w-sm w-full text-center shadow-2xl animate-in zoom-in duration-200 italic">
                <div class="w-16 h-16 bg-red-50 text-red-500 rounded-[2rem] flex items-center justify-center mx-auto mb-4 text-3xl">⚠️</div>
                <h3 class="text-xl font-black text-slate-900 mb-2 uppercase tracking-tighter">¿Eliminar?</h3>
                <div class="flex gap-4 mt-6">
                    <button onclick="window.closeConfirmModal()" class="flex-1 py-3 bg-slate-50 text-slate-500 border rounded-xl font-black uppercase text-[10px]">Cancelar</button>
                    <button id="confirm-btn-action" class="flex-1 py-3 bg-red-500 text-white rounded-xl font-black uppercase text-[10px]">Borrar</button>
                </div>
            </div>
        </div>

        <div id="size-guide-modal" class="fixed inset-0 z-[500] bg-slate-900/60 backdrop-blur-sm opacity-0 pointer-events-none hidden flex items-center justify-center p-4 transition-opacity duration-300" onclick="if(event.target === this) closeSizeGuide()">
            <div class="bg-white w-full max-w-sm rounded-[2rem] shadow-2xl overflow-hidden transform scale-90 transition-all duration-300 p-6 italic text-center relative" id="size-guide-content-box"></div>
        </div>

        <div id="client-policy-modal" class="fixed inset-0 z-[500] bg-slate-900/60 backdrop-blur-sm opacity-0 pointer-events-none hidden flex items-center justify-center p-4 transition-opacity duration-300" onclick="if(event.target === this) window.closeClientPolicy()">
            <div class="bg-white w-full max-w-sm rounded-[2rem] shadow-2xl overflow-hidden transform scale-90 transition-all duration-300 p-6 italic text-center relative" id="client-policy-content-box"></div>
        </div>

        <!-- Admin View -->
        <div id="view-admin" class="hidden py-6 px-4 lg:px-6 max-w-7xl mx-auto animate-in fade-in duration-300 italic text-left">
            <div class="flex flex-wrap border-b-2 border-slate-50 mb-6 gap-4 lg:gap-10 no-scrollbar overflow-x-auto">
                <button onclick="setAdminTab('inventory')" id="tab-inventory" class="pb-4 text-[9px] font-black uppercase tracking-widest admin-tab-active">Inventario</button>
                <button onclick="setAdminTab('attributes')" id="tab-attributes" class="pb-4 text-[9px] font-black uppercase tracking-widest text-slate-400">Atributos</button>
                <button onclick="setAdminTab('templates')" id="tab-templates" class="pb-4 text-[9px] font-black uppercase tracking-widest text-slate-400">Logística</button>
                <button onclick="setAdminTab('policies')" id="tab-policies" class="pb-4 text-[9px] font-black uppercase tracking-widest text-slate-400">Envíos/Pagos</button>
                <button onclick="setAdminTab('faqs')" id="tab-faqs" class="pb-4 text-[9px] font-black uppercase tracking-widest text-slate-400">FAQ</button>
                <button onclick="setAdminTab('pages')" id="tab-pages" class="pb-4 text-[9px] font-black uppercase tracking-widest text-slate-400">Páginas</button>
                <button onclick="setAdminTab('ai-config')" id="tab-ai-config" class="pb-4 text-[9px] font-black uppercase tracking-widest text-slate-400">IA</button>
                <button onclick="logout()" class="pb-4 text-[9px] font-black uppercase tracking-widest text-red-500 ml-auto">Salir</button>
            </div>

            <div id="admin-inventory" class="admin-pane space-y-6">
                <div class="flex flex-col md:flex-row justify-between md:items-center gap-4">
                    <h2 class="text-2xl font-black uppercase text-comfort">Stock Maestro</h2>
                    <div class="flex flex-wrap gap-2 w-full md:w-auto">
                        <input type="text" id="admin-kw" oninput="window.renderAdminProducts()" placeholder="Buscar..." class="p-3 bg-slate-50 border rounded-xl text-xs outline-none flex-grow italic">
                        <select id="admin-filter-cat" onchange="window.renderAdminProducts()" class="p-3 bg-slate-50 border rounded-xl text-xs admin-cat-select font-bold italic"></select>
                        <select id="admin-filter-badge" onchange="window.renderAdminProducts()" class="p-3 bg-slate-50 border rounded-xl text-xs admin-badge-select font-bold italic"></select>
                        <button onclick="window.seedDatabase()" class="bg-blue-50 text-blue-600 px-3 rounded-xl font-black text-[9px] uppercase shadow-sm tracking-widest">Carga</button>
                        <button onclick="openEditModal('prod')" class="bg-comfort text-white px-4 rounded-xl font-black text-[9px] uppercase shadow-md tracking-widest">Nuevo</button>
