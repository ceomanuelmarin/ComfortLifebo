        }

        async function compressImage(base64Str, maxWidth = 600, quality = 0.5) {
            return new Promise((resolve) => {
                const img = new Image();
                img.src = base64Str;
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    let width = img.width; let height = img.height;
                    if (width > maxWidth) { height = (maxWidth / width) * height; width = maxWidth; }
                    canvas.width = width; canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    resolve(canvas.toDataURL('image/jpeg', quality));
                };
            });
        }

        async function copyToClipboard(text) {
            try {
                await navigator.clipboard.writeText(text);
                return true;
            } catch (err) {
                const textArea = document.createElement("textarea");
                textArea.value = text;
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();
                try {
                    document.execCommand('copy');
                    document.body.removeChild(textArea);
                    return true;
                } catch (err2) {
                    document.body.removeChild(textArea);
                    return false;
                }
            }
        }

        window.shareLink = async (type, identifier, event) => {
            if (event) { event.stopPropagation(); event.preventDefault(); }
            let baseUrl = window.location.origin + window.location.pathname;
            let finalUrl = `${baseUrl}?${type}=${encodeURIComponent(identifier)}`;
            const shareData = { title: 'Comfort Life Bolivia', text: 'Mira esto en Comfort Life:', url: finalUrl };

            try {
                if (navigator.share) await navigator.share(shareData);
                else { await copyToClipboard(finalUrl); window.showToast("Enlace copiado 🔗"); }
            } catch (err) {
                await copyToClipboard(finalUrl); window.showToast("Copiado al portapapeles 📋");
            }
        };

