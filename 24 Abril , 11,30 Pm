            })).filter(item => item.q !== ""); 
            
            const data = { name: document.getElementById('faq-name').value, questions: JSON.stringify(qs) };
            if(id) await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'faqs', id), data);
            else await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'faqs'), data);
            window.closeFaqModal(); window.showToast("Guardado ✅");
        };

        window.isSeeding = false;
        window.seedDatabase = async () => {
            if(window.isSeeding) return;
            window.isSeeding = true;
            window.showToast("Cargando Catálogo...");
            
            try {
                const tRef = await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'templates'), {
                    name: "Logística Ejemplo", blocks: JSON.stringify([{key: "Envíos", value: "Todo el país en 48h hábiles"}, {key: "Garantía", value: "30 días por defecto de fábrica"}])
                });
                
                const polRef = await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'policies'), {
                    name: "Estándar Nacional",
                    shippingText: "Envíos a todo el país. Tiempo estimado 24 a 48 horas hábiles.\nCosto corre por cuenta del cliente.",
                    shippingImg: "",
                    paymentText: "Aceptamos transferencias y QR.\nEnvía tu comprobante una vez realizado el pago.",
                    paymentImg: ""
                });

                const initialCats = [{name: "Taloneras", color: "#1e3a8a", templateId: tRef.id}, {name: "Plantillas", color: "#2563eb", templateId: tRef.id}, {name: "Separadores", color: "#059669", templateId: tRef.id}, {name: "Compresión", color: "#7c3aed", templateId: tRef.id}, {name: "Protectores", color: "#db2777", templateId: tRef.id}, {name: "Accesorios", color: "#d97706", templateId: tRef.id}, {name: "Calzado", color: "#4b5563", templateId: tRef.id}, {name: "Masajeadores", color: "#4f46e5", templateId: tRef.id}, {name: "Infantil", color: "#0891b2", templateId: tRef.id}, {name: "Estabilizadores", color: "#b91c1c", templateId: tRef.id}, {name: "Cuidado Piel", color: "#15803d", templateId: tRef.id}, {name: "Insumos", color: "#374151", templateId: tRef.id}];
                const badNames = [{name: "Nuevo", color: "#10b981"}, {name: "Top Ventas", color: "#1e3a8a"}, {name: "Oferta", color: "#ef4444"}, {name: "Premium", color: "#8b5cf6"}, {name: "Bio", color: "#14b8a6"}, {name: "Pro", color: "#f59e0b"}];

                for (const cat of initialCats) await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'categories'), cat);
                for (const badge of badNames) await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'badges'), badge);

                const samples = Array.from({length: 30}, (_, i) => {
                    const price = 150 + (i * 10);
                    return {
                        name: `Prod Comfort Life ${i+1}`, price: price, comparePrice: i % 3 === 0 ? price + 50 : null,
                        category: initialCats[i % initialCats.length].name, highlight: badNames[i % badNames.length].name, variants: "S, M, L",
                        desc: "Solución ortopédica avanzada importada.", image: JSON.stringify([`https://images.unsplash.com/photo-${1560769629 + i}-975ec94e6a86?w=600`, `https://images.unsplash.com/photo-${1560769635 + i}-975ec94e6a86?w=600`]),
                        infoBlocks: JSON.stringify([{key: "Material", value: "Silicona Médica"}, {key: "Origen", value: "Importado"}]),
                        policyId: polRef.id
                    };
                });
                for (const sample of samples) await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'products'), sample);
                window.showToast("Carga Completa ✅");
            } catch(e) { window.showToast("Error de servidor ❌"); } finally { window.isSeeding = false; }
        };

        window.openAuthModal = () => document.getElementById('auth-modal').classList.remove('hidden');
        window.closeAuthModal = () => document.getElementById('auth-modal').classList.add('hidden');
        window.goToCategory = (cat) => { window.showSection('catalog'); window.filterCatalogUI(cat); };
        
        window.showSection = (s, slug = '') => {
            document.querySelectorAll('section, #view-admin').forEach(el => el.classList.add('hidden'));
            const target = document.getElementById(`section-${s}`) || document.getElementById('view-admin');
            if(target) target.classList.remove('hidden');
            if(s === 'custom' && slug !== '') {
                const p = pages.find(x => x.slug === slug);
                let content = p ? p.html : "Contenido no disponible.";
                if (p && p.faqId) content += buildFaqHtml(p.faqId); 
                document.getElementById('custom-renderer').innerHTML = content;
                const shareBtn = document.getElementById('custom-share-btn');
                if(shareBtn) shareBtn.onclick = (e) => window.shareLink('page', slug, e);
            }
            window.scrollTo({top:0, behavior: 'smooth'});
        };

        window.addImgUI = (val = "") => {
            const cont = document.getElementById('modal-images-container'); if(!cont) return;
            const div = document.createElement('div'); div.className = "img-entry flex gap-1 mb-1 items-center";
            div.innerHTML = `<input type="text" value="${val}" oninput="window.renderImgPreviews()" placeholder="https://..." class="f-img-url flex-grow p-1.5 bg-white border rounded text-[8px] italic outline-none"><button type="button" onclick="this.parentElement.remove(); window.renderImgPreviews()" class="text-red-400 p-1 font-bold text-xs">✕</button>`;
            cont.appendChild(div);
        };
        window.renderImgPreviews = () => {
            const previews = document.getElementById('img-previews'); if(!previews) return;
            const urls = Array.from(document.querySelectorAll('.f-img-url')).map(i => i.value).filter(v => v !== "");
            previews.innerHTML = urls.map(url => `<div class="relative w-8 h-8 rounded overflow-hidden border shadow-sm shrink-0"><img src="${url}" class="w-full h-full object-cover"></div>`).join('');
        };
        window.handleMultiImageFile = (input) => {
            const file = input.files[0]; if (!file) return;
            window.showToast("Optimizando..."); const reader = new FileReader();
            reader.onload = async (e) => { const comp = await compressImage(e.target.result); window.addImgUI(comp); window.renderImgPreviews(); window.showToast("Lista ✅"); };
            reader.readAsDataURL(file);
        };
        window.addBlockUI = (k = "", v = "") => {
            const cont = document.getElementById('modal-blocks-container'); if(!cont) return;
            const div = document.createElement('div'); div.className = "modal-blk flex gap-1 items-center bg-white p-1.5 rounded border italic mb-1 text-left";
            div.innerHTML = `<input type="text" value="${k}" placeholder="Dato" class="bk w-1/3 bg-transparent outline-none font-bold text-[8px] uppercase"><input type="text" value="${v}" placeholder="Valor" class="bv w-1/2 bg-transparent outline-none font-black text-[9px] uppercase tracking-tighter"><button type="button" onclick="this.parentElement.remove()" class="text-red-400 font-bold px-1">✕</button>`;
            cont.appendChild(div);
        };

        window.addAttribute = async (type) => {
            const idField = type === 'categories' ? 'edit-cat-id' : 'edit-badge-id';
            const name = document.getElementById(type === 'categories' ? 'new-cat-name' : 'new-badge-name').value.trim();
            const color = document.getElementById(type === 'categories' ? 'new-cat-color' : 'new-badge-color').value;
            const idVal = document.getElementById(idField).value;
            if(!name) return;
            const data = { name, color };
            if(type === 'categories') {
                data.templateId = document.getElementById('new-cat-template').value;
                data.faqId = document.getElementById('new-cat-faq').value; 
            }
            idVal ? await setDoc(doc(db, 'artifacts', appId, 'public', 'data', type, idVal), data) : await addDoc(collection(db, 'artifacts', appId, 'public', 'data', type), data);
            document.getElementById(type === 'categories' ? 'new-cat-name' : 'new-badge-name').value = "";
            if(type === 'categories') {
                document.getElementById('new-cat-template').value = "";
                document.getElementById('new-cat-faq').value = "";
            }
            document.getElementById(idField).value = ""; window.showToast("Guardado ✅");
        };

        window.loadAttrToEdit = (type, id) => {
            const item = (type === 'categories' ? categories : badges).find(x => x.id === id); if(!item) return;
            document.getElementById(type === 'categories' ? 'edit-cat-id' : 'edit-badge-id').value = item.id;
            document.getElementById(type === 'categories' ? 'new-cat-name' : 'new-badge-name').value = item.name;
            document.getElementById(type === 'categories' ? 'new-cat-color' : 'new-badge-color').value = item.color || "#1e3a8a";
            if(type === 'categories') {
                document.getElementById('new-cat-template').value = item.templateId || "";
                document.getElementById('new-cat-faq').value = item.faqId || "";
            }
            window.showToast("Editando ✅");
        };

        window.handleLogin = () => { if(document.getElementById('auth-pass').value === "admin1987") { window.showSection('admin'); document.getElementById('auth-modal').classList.add('hidden'); window.showToast("Bienvenido ✅"); } else { window.showToast("Clave Incorrecta ❌"); } };
        window.logout = () => location.reload();
        window.setAdminTab = (t) => { document.querySelectorAll('.admin-pane').forEach(v => v.classList.add('hidden')); document.getElementById(`admin-${t}`).classList.remove('hidden'); document.querySelectorAll('[id^="tab-"]').forEach(b => b.classList.remove('admin-tab-active')); document.getElementById(`tab-${t}`).classList.add('admin-tab-active'); window.renderAttrManager(); };
        window.showToast = (m) => { const t = document.getElementById('toast'); if(t){ t.innerText = m; t.classList.remove('translate-y-28'); setTimeout(() => t.classList.add('translate-y-28'), 3000); }};
        window.saveAIConfig = async () => { await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'aiConfig'), { prompt: document.getElementById('ai-prompt-config').value }); window.showToast("IA Lista ✅"); };

        window.deleteData = (col, id) => {
            const modal = document.getElementById('confirm-modal');
            const btnConfirm = document.getElementById('confirm-btn-action');
            modal.classList.remove('hidden');
            btnConfirm.onclick = async () => {
                window.closeConfirmModal();
                try { await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', col, id)); window.showToast("Borrado ✅"); } 
                catch(e) { window.showToast("Error al borrar ❌"); }
            };
        };

        window.generateProductInfoWithAI = async () => {
            const name = document.getElementById('f-name').value.trim(); const cat = document.getElementById('f-cat').value;
            if (!name) return window.showToast("⚠️ Nombre primero");
            window.showToast("✨ IA...");
            try {
                const prompt = `Experto ortopedia médica. Producto "${name}" categoría "${cat}". Devuelve JSON exacto: {"desc": "Desc persuasiva max 2 líneas.", "variants": "Ej S, M", "blocks": [{"key": "Material", "value": "Silicona"}]}`;
                const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }], generationConfig: { responseMimeType: "application/json" } }) });
                const d = await res.json(); const data = JSON.parse(d.candidates[0].content.parts[0].text);
                if(data.desc) document.getElementById('f-desc').value = data.desc;
                if(data.variants) document.getElementById('f-vars').value = data.variants;
                if(data.blocks && Array.isArray(data.blocks)) { document.getElementById('modal-blocks-container').innerHTML = ''; data.blocks.forEach(b => window.addBlockUI(b.key, b.value)); }
                window.showToast("✨ ¡Listo!");
            } catch (e) { window.showToast("❌ Error IA"); }
        };

        window.generateLandingWithAI = async () => {
            const name = document.getElementById('f-name').value.trim();
            if (!name) return window.showToast("⚠️ Nombre primero");
            window.showToast("✨ HTML...");
            try {
                const prompt = `Código HTML sin tags html/body para "Análisis Clínico Avanzado" de "${name}". Tailwind, minimalista text-blue-900. 3 beneficios. Solo HTML puro.`;
                const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] }) });
                const d = await res.json();
                document.getElementById('f-landing').value = d.candidates[0].content.parts[0].text.replace(/```html/g, '').replace(/```/g, '').trim();
                window.showToast("✨ Generado!");
            } catch (e) { window.showToast("❌ Error HTML"); }
        };

        window.askAI = async (source = 'embedded') => {
            const input = document.getElementById(source === 'embedded' ? 'ai-input-embedded' : 'ai-input-floating'); 
            const msg = input.value.trim(); if(!msg) return;
            const chat = document.getElementById(source === 'embedded' ? 'ai-messages-embedded' : 'ai-messages-floating');
            chat.innerHTML += `<div class="bg-comfort text-white px-3 py-1.5 rounded-xl rounded-tr-none text-[9px] ml-auto w-fit max-w-[85%] shadow-sm font-bold text-right">${msg}</div>`;
            input.value = ""; chat.scrollTop = chat.scrollHeight;
            try {
                const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ contents: [{ parts: [{ text: `Contexto: ${aiSystemPrompt}. Cliente: ${msg}` }] }] }) });
                const d = await res.json(); const rawText = d.candidates?.[0]?.content?.parts?.[0]?.text || "No pude procesarlo.";
                const formattedText = `<p>${rawText.replace(/\n\n/g, '</p><p class="mt-1.5">').replace(/\n/g, '<br>')}</p>`;
                let suggestionsHTML = "";
                if(products.length > 0) {
                    const selected = [...products].sort(() => 0.5 - Math.random()).slice(0, 2);
                    suggestionsHTML = `<div class="mt-2 pt-2 border-t border-slate-100 flex flex-wrap gap-1.5"><span class="w-full text-[7px] font-black text-slate-400 uppercase tracking-widest">Sugerencias:</span>${selected.map(p => `<button onclick="window.openProductQuickView('${p.id}')" class="px-2 py-1 bg-blue-50 hover:bg-blue-100 text-blue-600 border border-blue-100 rounded-md text-[8px] font-black uppercase transition text-left truncate max-w-full">${p.name}</button>`).join('')}</div>`;
                }
                chat.innerHTML += `<div class="bg-white px-3 py-2 rounded-xl rounded-tl-none border border-slate-100 shadow-sm text-[9px] text-slate-600 w-fit max-w-[95%] self-start flex flex-col gap-1 leading-relaxed font-medium">${formattedText}${suggestionsHTML}</div>`;
                chat.scrollTop = chat.scrollHeight;
            } catch(e) { window.showToast("Error IA ❌"); }
        };

        function syncData() {
            if (!currentUser) return;
            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'products'), (sn) => {
                products = sn.docs.map(d => ({id: d.id, ...d.data()}));
                if (products.length === 0 && !window.isSeeding) window.seedDatabase(); 
                window.renderAdminProducts(); window.filterCatalogUI(); window.renderHome(); window.processDeepLink(); 
            }, (error) => console.error("Error productos:", error));
            
            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'categories'), (sn) => {
                categories = sn.docs.map(d => ({id: d.id, ...d.data()}));
                window.renderHome(); window.updateSelectors(); window.renderCatalogFilters(); window.renderAttrManager();
            }, (error) => console.error("Error cats:", error));

            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'badges'), (sn) => {
                badges = sn.docs.map(d => ({id: d.id, ...d.data()}));
                window.updateSelectors(); window.renderAttrManager();
            }, (error) => console.error("Error badges:", error));

            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'templates'), (sn) => {
                templates = sn.docs.map(d => ({id: d.id, ...d.data()}));
                window.renderAdminTemplates(); window.updateSelectors(); window.renderAttrManager();
            }, (error) => console.error("Error templates:", error));

            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'policies'), (sn) => {
                policies = sn.docs.map(d => ({id: d.id, ...d.data()}));
                window.renderAdminPolicies(); window.updateSelectors(); window.renderAttrManager();
            }, (error) => console.error("Error policies:", error));

            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'faqs'), (sn) => {
                faqs = sn.docs.map(d => ({id: d.id, ...d.data()}));
                window.renderAdminFaqs(); window.updateSelectors(); window.renderAttrManager();
            }, (error) => console.error("Error FAQs:", error));

            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'pages'), (sn) => {
                pages = sn.docs.map(d => ({id: d.id, ...d.data()}));
                window.updateNav();
                window.renderAdminPages(); 
            }, (error) => console.error("Error páginas:", error));
        }

        const start = async () => {
            if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) await signInWithCustomToken(auth, __initial_auth_token);
            else await signInAnonymously(auth);
            onAuthStateChanged(auth, (user) => { currentUser = user; if (user) syncData(); });
        };
        start();
    </script>
</body>
</html>
